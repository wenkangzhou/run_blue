# ─────────────────────────────────────────
# 必填：Strava API
# 访问 https://www.strava.com/settings/api 创建应用获取
# Authorization Callback Domain 必须填写你部署的域名（如 localhost 或 your-domain.com）
# ─────────────────────────────────────────
NEXT_PUBLIC_STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# 可选：本地脚本更新 public/data/activities.json 时使用
# 只放在 .env.local，不要提交到仓库
# STRAVA_REFRESH_TOKEN=your_strava_refresh_token

# ─────────────────────────────────────────
# 必填：应用 URL
# 本地开发: http://localhost:6364
# 生产部署: https://your-domain.com
# 必须与 Strava 后台 Authorization Callback Domain 一致
# ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:6364

# ─────────────────────────────────────────
# 必填：AI 训练分析（Moonshot / Kimi）
# 访问 https://platform.moonshot.cn 注册并创建 API Key
# 不提供此 Key 时 AI 分析功能将不可用，应用仍可正常使用其他功能
# ─────────────────────────────────────────
KIMI_API_KEY=your_kimi_api_key

# 可选：本地个人使用时，通过 Claude Code + 官方 Strava MCP 生成分析
# 先在项目目录执行官方配置命令并完成一次授权：
# claude mcp add --transport http strava-run-blue-probe https://mcp.strava.com/mcp
# STRAVA_AI_PROVIDER=claude-mcp
# CLAUDE_CODE_PATH=/opt/homebrew/bin/claude
# STRAVA_MCP_SERVER_NAME=strava-run-blue-probe
# STRAVA_MCP_CLAUDE_MODEL=sonnet

# ─────────────────────────────────────────
# 可选：MapTiler 地图密钥
# 访问 https://cloud.maptiler.com 免费获取，用于国内地图瓦片加速
# 不配置时自动回退到 OpenStreetMap
# ─────────────────────────────────────────
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key

# ─────────────────────────────────────────
# 可选预留：Supabase（仅服务端，当前未接入主流程）
# 配置后不会自动开启云同步；需要在服务端 auth/profile/plan 流程中显式接入
# 不配置时活动数据保存在 IndexedDB，其它偏好/计划保存在 localStorage，Strava token 保存在 HttpOnly Cookie
# 注意：SERVICE_ROLE_KEY 只能放在服务端环境变量中，不要添加 NEXT_PUBLIC_ 前缀
# ─────────────────────────────────────────
# SUPABASE_URL=your_supabase_url
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
